{% extends 'base.html.twig' %}

{% block title %}🍕 Order Pizza{% endblock %}

{% block body %}
<div data-controller="cart" class="flex flex-col lg:flex-row gap-8">

    {# Pizza Menu #}
    <div class="flex-1">
        <h2 class="text-3xl font-black text-tp-text mb-6">Choose your pizza 🍕</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            {% for pizza in pizzas %}
            <div class="bg-tp-surface rounded-2xl overflow-hidden border border-tp-border hover:border-tp-purple transition-colors">
                <img src="/images/pizzas/{{ pizza.imageUrl }}"
                     alt="{{ pizza.name }}"
                     class="w-full h-48 object-cover">
                <div class="p-4">
                    <h3 class="text-lg font-bold mb-1 text-tp-text">{{ pizza.name }}</h3>
                    <p class="text-sm text-tp-muted mb-4 line-clamp-2">{{ pizza.description|striptags }}</p>
                    <button
                        data-action="cart#add"
                        data-cart-id-param="{{ pizza.id }}"
                        data-cart-name-param="{{ pizza.name }}"
                        class="w-full bg-tp-purple text-white rounded-xl py-2 font-semibold hover:bg-tp-purple-hover active:scale-95 transition-all">
                        + Add to cart
                    </button>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    {# Cart + Recent Orders Sidebar #}
    <div class="lg:w-80 shrink-0 flex flex-col gap-4">
        <div class="bg-tp-surface rounded-2xl border border-tp-border sticky top-6">
            <div class="p-5 border-b border-tp-border">
                <h2 class="text-xl font-black flex items-center gap-2 text-tp-text">
                    🛒 Your Cart
                    <span class="bg-tp-purple text-white text-xs font-bold rounded-full w-6 h-6 flex items-center justify-center"
                          data-cart-target="count">0</span>
                </h2>
            </div>

            <div class="p-5 min-h-32" data-cart-target="cartItems">
                <p class="text-tp-muted text-sm text-center mt-6">Your cart is empty</p>
            </div>

            <div class="p-5 border-t border-tp-border" data-cart-target="checkoutSection">
                <div class="mb-4 text-sm text-tp-muted flex items-center gap-2">
                    Price:
                    <span data-cart-target="coinsDisplay" class="inline-flex items-center">
                        <span class="text-tp-muted">—</span>
                    </span>
                </div>
                <p class="text-red-400 text-sm mb-2 min-h-5" data-cart-target="error"></p>
                <form method="post" action="{{ path('customer_order') }}" data-cart-target="form" data-action="submit->cart#submit">
                    <div class="mb-3">
                        <label class="block text-sm font-medium text-tp-muted mb-1">Your email</label>
                        <input type="email" name="email" value="customer@example.com" aria-label="Customer E-Mail Address"
                               data-cart-target="emailInput"
                               class="w-full bg-tp-bg border border-tp-border rounded-xl px-3 py-2 text-sm text-tp-text focus:outline-none focus:ring-2 focus:ring-tp-purple">
                    </div>
                    <button type="submit"
                            data-cart-target="checkoutBtn"
                            disabled
                            class="w-full bg-tp-purple text-white rounded-xl py-3 font-bold hover:bg-tp-purple-hover disabled:opacity-40 disabled:cursor-not-allowed active:scale-95 transition-all">
                        🍕 Place Order
                    </button>
                </form>
            </div>
        </div>

        {% if recentOrders %}
        <div class="bg-tp-surface rounded-2xl border border-tp-border p-5">
            <h2 class="text-lg font-black mb-3 text-tp-text">🕐 Recent Orders</h2>
            <ul class="space-y-2">
                {% for order in recentOrders %}
                <li>
                    <a href="{{ path('customer_status', {id: order.id}) }}"
                       class="flex items-center justify-between text-sm hover:text-tp-purple-light transition-colors">
                        <span class="text-tp-muted">#{{ order.id }} &mdash; {{ order.createdAt|date('M d, H:i') }}</span>
                        <span class="font-semibold text-tp-text">{{ order.status.value }}</span>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    </div>

</div>
{% endblock %}
